#!/bin/bash
# Install CPAN modules

source "$(dirname "${BASH_SOURCE[0]}")/./common"

INIT status "Install CPAN"
INIT apt-install cpan


INIT status "Install CPAN base modules"
sudo cpan CPAN YAML Term::ReadLine::Perl Test::Exception


INIT status "Install common CPAN modules"
sudo cpan \
	Config::IniFiles \
	Data::Dump \
	Digest::MD5::File \
	File::Basename \
	File::DirWalk \
	File::Slurp \
	Getopt::Long \
	IMDB::Film \
	Number::Bytes::Human \
	Term::ReadKey \
	Text::Glob \


